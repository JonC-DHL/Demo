<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_Labeler_Module" Id="{0e81e583-f9da-4a83-b6b7-30e0502830e9}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Labeler_Module EXTENDS FB_PackML_BaseModule
VAR
	// Sub module definitions here
	Infeed_Vision_Sensor		: FB_Vision_Barcode_SubModule		:= (Name := 'Infeed_Vision_Sensor', LogStateChanges := TRUE);
	Labeler						: FB_Labeler_SubModule				:= (Name := 'Labeler', LogStateChanges := TRUE);
	Outfeed_Vision_Sensor		: FB_Vision_Barcode_SubModule		:= (Name := 'Outfeed_Vision_Sensor', LogStateChanges := TRUE);
	
	// List of sub modules
	ipSubModules_Init : ARRAY[1..Parameters_PackML_Base.MAX_NO_OF_SUBMODULES] OF I_PackML_BaseModule := [];

	// Component definitions here
//	Axis   : FB_Component_BasicAxis := (Name := 'Axis');
	Sensor : FB_DigitalSensor		:= (Name := 'Sensor');

	//Alarms for this module
	LabelerAlarms : ARRAY[1..LABELER_ALARM_COUNT] OF FB_TcAlarm;

	//Data for recipe
	Recipe : ST_LabelerRecipe;

	(*Parameters from PackTags for module
    //_Param  : ARRAY[1..10] OF ST_Descriptor2;*)
	_Report : ARRAY[1..10] OF ST_Descriptor2;

	//HMI Control for EM
	fbControlSourceHMI : FB_ControlSource_HMI;
END_VAR

VAR CONSTANT
	//reports 
	FAULT : INT := 1;

	//Alarms
	LABELER_ALARM_COUNT : INT := 5;
END_VAR

//Simulation variables for messaging
VAR
	ErrorInput : BOOL;
	WarnInput  : BOOL;
	InfoInput  : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
