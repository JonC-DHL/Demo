    <Method Name="Aborting" Id="{dc59c832-eaf6-464b-8903-89565c0e1779}" FolderPath="Methods\Acting States\">
      <Declaration><![CDATA[METHOD PROTECTED Aborting
VAR_INPUT
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE SequenceState OF
	0:
		NoStateTasksToComplete := FALSE;
		SequenceState		   := SequenceState + 10;

	10:
		Axis.Stop();
		IF Axis.Stopped THEN
			SequenceState := SequenceState + 10;
		END_IF

	20:
		// Disable here
		Axis.Disable();

		// Check not enabled here
		IF NOT Axis.Enabled THEN
			SequenceState := SequenceState + 10;
		END_IF

	30:
		StateTasksComplete := TRUE;
END_CASE

SUPER^.Aborting();]]></ST>
      </Implementation>
    </Method>
