<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_SingleDrive_Conveyor_With_Out_Sensor" Id="{b6c1227a-7c2f-47ae-afd0-41758dbe9e10}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_SingleDrive_Conveyor_With_Out_Sensor EXTENDS FB_PackML_BaseModule
VAR
	// Sub module definitions here

	// List of sub modules
	ipSubModules_Init : ARRAY[1..Parameters_PackML_Base.MAX_NO_OF_SUBMODULES] OF I_PackML_BaseModule := [];

	// Component definitions here
//	Axis   : FB_Component_BasicAxis := (Name := 'Axis');
//	Sensor : FB_DigitalSensor		:= (Name := 'Sensor');
	Previous_Sensor	:I_DigitalSensorBase;
	OutFeed_Sensor	:I_DigitalSensorBase;

	//Alarms for this module
	ConveyorModuleAlarms : ARRAY[1..CONVEYOR_MODULE_ALARM_COUNT] OF FB_TcAlarm;

	//Data for recipe
	Recipe : ST_Closer_Recipe;

	(*Parameters from PackTags for module
    //_Param  : ARRAY[1..10] OF ST_Descriptor2;*)
	_Report : ARRAY[1..10] OF ST_Descriptor2;

	//HMI Control for EM
	fbControlSourceHMI : FB_ControlSource_HMI;
END_VAR

VAR CONSTANT
	//reports 
	FAULT : INT := 1;

	//Alarms
	CONVEYOR_MODULE_ALARM_COUNT : INT := 5;
END_VAR

//Simulation variables for messaging
VAR
	ErrorInput : BOOL;
	WarnInput  : BOOL;
	InfoInput  : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(*
Execute = Run conveyor
			if no infeed from previous for 1min go to idle - stop drive, wait for previous outfeed or previous operation busy? ?
			If out feed blocked, then stop at sensor - blocked until next is clear
			
			




*)]]></ST>
    </Implementation>
