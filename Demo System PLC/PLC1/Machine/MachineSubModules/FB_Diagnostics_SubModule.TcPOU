<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_Diagnostics_SubModule" Id="{e8d5c8cf-1c94-444b-a93d-3e561b3fa074}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Diagnostics_SubModule EXTENDS FB_PackML_BaseModule
VAR //https://beckhoff-usa-community.github.io/SPT-Libraries/SPT%20Training/SafetyMonitoring.html
	// Sub module definitions here

	// List of sub modules
	ipSubModules_Init : ARRAY[1..Parameters_PackML_Base.MAX_NO_OF_SUBMODULES] OF I_PackML_BaseModule := [];

	// Component definitions here
//	Axis   : FB_Component_BasicAxis := (Name := 'Axis');
//	Sensor : FB_DigitalSensor		:= (Name := 'Sensor');
//	    // EtherCat Diagnostics
 // EtherCat Diagnostics
    {attribute 'TcLinkTo' := '.EtherCatMaster.AmsNetID     := TIID^<default>^InfoData^AmsNetId;
                            .EtherCatMaster.DevID        := TIID^<default>^InfoData^DevId;
                            .EtherCatMaster.DevState     := TIID^<default>^Inputs^DevState;
                            .EtherCatMaster.ChangeCount  := TIID^<default>^InfoData^ChangeCount;
                            .EtherCatMaster.SlaveCount   := TIID^<default>^Inputs^SlaveCount;
                            .EtherCatMaster.CfgSlaveCount:= TIID^<default>^InfoData^CfgSlaveCount;
                            .FrmXWcState[0]              := TIID^<default>^Inputs^Frm0WcState;
                            .FrmXWcState[1]              := TIID^<default>^Inputs^Frm1WcState;
                            .FrmXWcState[2]              := TIID^<default>^Inputs^Frm2WcState;
                            .FrmXWcState[3]              := TIID^<default>^Inputs^Frm3WcState;
                            .FrmXWcState[4]              := TIID^<default>^Inputs^Frm4WcState;
                            .FrmXWcState[5]              := TIID^<default>^Inputs^Frm5WcState;
                            .FrmXWcState[6]              := TIID^<default>^Inputs^Frm6WcState;
                            .FrmXWcState[7]              := TIID^<default>^Inputs^Frm7WcState;
                            .FrmXWcState[8]              := TIID^<default>^Inputs^Frm8WcState;
                            .FrmXWcState[9]              := TIID^<default>^Inputs^Frm9WcState'}
    EtherCatMasterX001 : FB_Component_EtherCatMaster := (Name := 'X001');
	
//	    {attribute 'TcLinkTo' := '.SyncUnitTaskInfo.WcState    := TIID^Device_5^SyncUnits^<default>^<unreferenced>^WcState^WcState;
//                            .SyncUnitTaskInfo.ObjectId   := TIID^Device_5^SyncUnits^<default>^<unreferenced>^InfoData^ObjectId;
//                            .SyncUnitTaskInfo.State      := TIID^Device_5^SyncUnits^<default>^PlcTask^InfoData^State;
//                            .SyncUnitTaskInfo.SlaveCount := TIID^Device_5^SyncUnits^<default>^PlcTask^InfoData^SlaveCount'}
//    SyncUnitStandardSlowTask : FB_SyncUnitTask(EtherCatMaster := EtherCatMasterX001);


	//Alarms for this module
	DiagnosticsAlarms : ARRAY[1..DIAGNOSTICS_ALARM_COUNT] OF FB_TcAlarm;

	//Data for recipe
	Recipe : ST_Diagnostics_Recipe;

	(*Parameters from PackTags for module
    //_Param  : ARRAY[1..10] OF ST_Descriptor2;*)
	_Report : ARRAY[1..10] OF ST_Descriptor2;

	//HMI Control for EM
	fbControlSourceHMI : FB_ControlSource_HMI;
END_VAR

VAR CONSTANT
	//reports 
	FAULT : INT := 1;

	//Alarms
	DIAGNOSTICS_ALARM_COUNT : INT := 5;
END_VAR

//Simulation variables for messaging
VAR
	ErrorInput : BOOL;
	WarnInput  : BOOL;
	InfoInput  : BOOL;
	
	bResetIO	:BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
