<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_Diverter_Module001" Id="{50568873-dc6a-4c9e-a276-6bb23a8a9804}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Diverter_Module001 EXTENDS FB_PackML_BaseModule
VAR
	// Sub module definitions here

	// List of sub modules
	ipSubModules_Init : ARRAY[1..Parameters_PackML_Base.MAX_NO_OF_SUBMODULES] OF I_PackML_BaseModule := [];

	// Component definitions here
//	Axis   : FB_Component_BasicAxis := (Name := 'Axis');
	Drive_1	:I_Drive_Type_1_Axis;
	Drive_2	:I_Drive_Type_1_Axis;
	Sensor : FB_DigitalSensor		:= (Name := 'Sensor');

	//Alarms for this module
	DiverterAlarms : ARRAY[1..DIVERTER_ALARM_COUNT] OF FB_TcAlarm;

	//Data for recipe
	Recipe : ST_DiverterRecipe;

	(*Parameters from PackTags for module
    //_Param  : ARRAY[1..10] OF ST_Descriptor2;*)
	_Report : ARRAY[1..10] OF ST_Descriptor2;

	//HMI Control for EM
	fbControlSourceHMI : FB_ControlSource_HMI;
END_VAR

VAR CONSTANT
	//reports 
	FAULT : INT := 1;

	//Alarms
	DIVERTER_ALARM_COUNT : INT := 5;
END_VAR

//Simulation variables for messaging
VAR
	ErrorInput : BOOL;
	WarnInput  : BOOL;
	InfoInput  : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
