  <POU Name="FB_MotionlinxAI_Controller" Id="{c6418492-3e13-4469-9001-1d04ff4ed1bd}" SpecialFunc="None">
    <Declaration><![CDATA[(*	
*)
FUNCTION_BLOCK FB_MotionlinxAI_Controller EXTENDS FB_ComponentBase IMPLEMENTS I_MotionlinxAI_Controller_Sts
VAR
//Inputs
	iSensors AT%I* : INT;
	iSysDiagnostics AT%I* : BYTE;
//	Drive_1_Left	  : FB_MotionlinxAI_Axis (Main_Sensor	:= iSensors.4, Aux_Sensor	:= iSensors.0 ):= (Name := 'Left Drive 1');
//	Drive_2_Right	  : FB_MotionlinxAI_Axis (Main_Sensor	:= iSensors.6, Aux_Sensor	:= iSensors.2 ):= (Name := 'Right Drive 2');
	

	//Output
	oServoControl AT%Q* : INT;
	oSetPin2Out AT%Q* : BYTE;
	oClearMotorError  AT%Q* : BYTE;
	
	//From Other project, can possibly be modifdied a bit
	//Connection Monitoring//
	bWCState AT%I* : BOOL; //0 is Data Valid, 1 is Data Invalid
	
	tonCommunicationsFailed : TON;
	bCommunicationsFailed : BOOL;
	
	bInputToggle AT%I* : BOOL;

	// Internal variables
	//Error Resetting//
	bError : BOOL;
	tpErrorReset : TP;
	
	//Speed Limits//
	rPGDMaxSpeed : REAL := 536.0;
	rPGDMinSpeed : REAL := 3888.0;
	
	
	//Motor Status//
	eMotorStatus: MotionlinxAI_Motor_Status;
	eErrorRecord : MotionlinxAI_Error_States;
	_stController_Sts	:ST_Controller_Status;

	
	
	
//	_ExtendRequest	: BOOL;
//	_RetractRequest : BOOL;
//	_Extended		: BOOL;
//	_Retracted		: BOOL;
//	_Extending		: BOOL;
//	_Retracting		: BOOL;
//	_ExtendTime		: LREAL := 1000; // Default time 1s
//	_RetractTime	: LREAL := 1000; // Default time 1s

//	// Timer for Extend/Retract
//	Extend_TON	  : TON;
//	Retract_TON	  : TON;
//	Extend_RTRIG  : R_TRIG;
//	Retract_RTRIG : R_TRIG;

	//HMI 
	MotionlinxAI_Controller_HMI : ST_MotionlinxAI_Axis_HMI;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
