    <Method Name="CyclicLogic" Id="{9783bca3-b635-4c58-8c9e-beb54e6bccd3}" FolderPath="I_CyclicFB\">
      <Declaration><![CDATA[METHOD CyclicLogic
VAR

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//////////Error Handling//////////
errorCheck();
_stController_Sts.Sensors	:= iSensors;
_stController_Sts.bEnabled	:= isEnabled;
_stController_Sts.HasFault	:= HasFault;

//////////Set Speed Limits//////////
//uLMinSpeed := 15+uLMaxSpeed/100;
//uRMinSpeed := 15+uRMaxSpeed/100;
//////////Set Speeds//////////
//oMotorLSpeed := LIMIT(UINT_TO_INT(uLMinSpeed),UINT_TO_INT(nRequestedSpeedLeft),UINT_TO_INT(uLMaxSpeed));
//oMotorRSpeed := LIMIT(UINT_TO_INT(uRMinSpeed),UINT_TO_INT(nRequestedSpeedRight),UINT_TO_INT(uRMaxSpeed));


////////////Stop On Disable//////////
//IF NOT bEnabled THEN
//	oMotorLDecel := oMotorRDecel := 500;	
//	oMotorLControl.0 := oMotorRControl.0 := FALSE;
//ELSE
//	oMotorLDecel := oMotorRDecel := 500;
//END_IF;



//////////Communications Monitoring//////////
tonCommunicationsFailed(IN:= bWCState, PT:= T#10S, Q => bCommunicationsFailed);


//One shot the requests


//Handle Extend
//IF Extend_RTRIG.Q THEN
//	Output			:= TRUE;
//	_Extending		:= TRUE;
//	_Retracting		:= FALSE;
//	_Retracted		:= FALSE;
//	_RetractRequest := FALSE;
//END_IF

//Handle Retract
//IF Retract_RTRIG.Q THEN
//	Output		   := FALSE;
//	_Extending	   := FALSE;
//	_Retracting	   := TRUE;
//	_Extended	   := FALSE;
//	_ExtendRequest := FALSE;
//END_IF

//Handle the time to Extend/Retract
//Extend_TON(IN := _Extending, PT := LREAL_TO_TIME(_ExtendTime));
//Retract_TON(IN := _Retracting, PT := LREAL_TO_TIME(_RetractTime));
//IF Extend_TON.Q THEN
//	_Extended  := TRUE;
//	_Extending := FALSE;
//END_IF

//IF Retract_TON.Q THEN
//	_Retracted	:= TRUE;
//	_Retracting := FALSE;
//END_IF

SUPER^.CyclicLogic();]]></ST>
      </Implementation>
    </Method>
