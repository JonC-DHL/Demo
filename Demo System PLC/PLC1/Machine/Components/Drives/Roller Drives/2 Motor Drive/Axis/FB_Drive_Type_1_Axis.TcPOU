      <Declaration><![CDATA[PROPERTY Position : real]]></Declaration>
      <Get Name="Get" Id="{dff93807-27f0-402a-b451-634a9ea6bd4a}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
