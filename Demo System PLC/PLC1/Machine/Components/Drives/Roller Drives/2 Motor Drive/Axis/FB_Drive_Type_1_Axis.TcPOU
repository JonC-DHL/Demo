      </Get>
      <Set Name="Set" Id="{18e65aeb-ff98-42c8-8f8b-6c305d710641}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[]]></ST>
        </Implementation>
      </Set>
    </Property>
  </POU>
</TcPlcObject>