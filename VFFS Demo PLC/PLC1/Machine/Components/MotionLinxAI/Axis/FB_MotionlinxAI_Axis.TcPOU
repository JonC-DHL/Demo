    <Method Name="CreateEvents" Id="{e0f8766d-dc7c-457b-9343-3c71d71e0eda}" FolderPath="I_ComponentBase\">
      <Declaration><![CDATA[METHOD PROTECTED CreateEvents
VAR_INPUT
