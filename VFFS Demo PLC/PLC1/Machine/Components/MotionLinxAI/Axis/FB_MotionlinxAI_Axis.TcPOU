      </Set>
    </Property>
    <Method Name="Disable" Id="{1d453f6e-3687-4412-ae4d-5e48024c3ad0}" FolderPath="I_MotionlinxAI_Axis\">
      <Declaration><![CDATA[METHOD Disable : BOOL
(*BRAKING MODES:
	0 : NORMAL - HOLDS IN PLACE BY SHORTING WINDINGS
	1 : FREE - NOT HELD IN PLACE
	2 : SERVO - MAINTAINS POSITION BASED ON HALLS EFFECT SENSOR*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[//oMotorDecel := 500;
bEnabled := FALSE;

]]></ST>
      </Implementation>
    </Method>
    <Method Name="EmergencyStop" Id="{8591e24a-3de3-441d-a69f-a1e1e7e28cb2}" FolderPath="I_MotionlinxAI_Axis\">
      <Declaration><![CDATA[METHOD EmergencyStop : BOOL
(*BRAKING MODES:
	0 : NORMAL - HOLDS IN PLACE BY SHORTING WINDINGS
	1 : FREE - NOT HELD IN PLACE
	2 : SERVO - MAINTAINS POSITION BASED ON HALLS EFFECT SENSOR*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[oMotorDecel:= 1;
oMotorControl.0 := FALSE;
bEnabled := FALSE;
oMotorBrakeMode := 0;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Enable" Id="{e5af88bd-408e-4e07-8d90-41c559ff9446}" FolderPath="I_MotionlinxAI_Axis\">
      <Declaration><![CDATA[METHOD Enable : BOOL
VAR_INPUT
//	Acceleration	:INT;	//Should not be here, but part of recipe
END_VAR
(*BRAKING MODES:
	0 : NORMAL - HOLDS IN PLACE BY SHORTING WINDINGS
	1 : FREE - NOT HELD IN PLACE
	2 : SERVO - MAINTAINS POSITION BASED ON HALLS EFFECT SENSOR*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[bEnabled := TRUE;
//oMotorAccel	:= Acceleration;
//oMotorControl.0 := TRUE;
//oMotorBrakeMode  := 2;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Enabled" Id="{584b0cad-97bc-486f-baa5-ad501022e39e}" FolderPath="I_MotionlinxAI_Axis\">
      <Declaration><![CDATA[PROPERTY Enabled : BOOL]]></Declaration>
      <Get Name="Get" Id="{dc9be4db-7694-42dc-a45a-bd0ea8a3eb63}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Enabled := bEnabled;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Action Name="errorCheck" Id="{5b89c9f1-6a13-405d-9c8a-b081e6c5d852}" FolderPath="I_MotionlinxAI_Axis\">
      <Implementation>
        <ST><![CDATA[//oClearMotorError := 0;	//Action. this goes to the contrroller and that sends the reset requests
IF  iDiagnostics.5  THEN
	eError := MotionlinxAI_Error_States.MOTOR_BOARD_OVERHEAT;
(*ELSIF iDiagnosticsL.6  THEN
	eErrorLeft := MotionlinxAI_Error_States.MOTOR_OVERVOLTAGE;
ELSIF iDiagnosticsL.7  THEN
	eErrorLeft := MotionlinxAI_Error_States.MOTOR_UNDERVOLTAGE;*)
ELSIF iDiagnostics.8  THEN
	eError := MotionlinxAI_Error_States.MOTOR_OVERHEATED;
(*ELSIF iDiagnosticsL.9  THEN
	eErrorLeft := MotionlinxAI_Error_States.MOTOR_MAX_TORQUE;*)
ELSIF iDiagnostics.10  THEN
	eError := MotionlinxAI_Error_States.MOTOR_SHORT_CIRCUIT;
ELSIF iDiagnostics.11  THEN
	eError := MotionlinxAI_Error_States.MOTOR_NOT_CONNECTED;
ELSIF iDiagnostics.12  THEN
	eError := MotionlinxAI_Error_States.MOTOR_OVERLOADED;
ELSIF iDiagnostics.13  THEN
	eError := MotionlinxAI_Error_States.MOTOR_STALLED;
ELSIF iDiagnostics.14  THEN
	eError := MotionlinxAI_Error_States.MOTOR_HALL_SENSOR;
ELSE
	eError := MotionlinxAI_Error_States.NO_ERROR;
END_IF;



bMotorDisconnected := eError = MotionlinxAI_Error_States.MOTOR_NOT_CONNECTED;

IF eError <> MotionlinxAI_Error_States.NO_ERROR  OR eError = MotionlinxAI_Error_States.MOTOR_UNDERVOLTAGE  THEN
	IF (bMotorDisconnected AND NOT bMotorExpected)  THEN
		_Error := FALSE;
	ELSE
		_Error := TRUE;
		eError := eError;
	
			
//		IF oClearMotorError = 0 THEN
//			oClearMotorError := 1;
//		ELSIF oClearMotorError = 1 THEN
//			oClearMotorError := 0;
//		END_IF;
	END_IF

ELSE
	_Error := FALSE;
END_IF;]]></ST>
      </Implementation>
    </Action>
    <Property Name="HasFault" Id="{97dbf5df-348c-4c25-b4a9-4d7e37e13d72}" FolderPath="I_MotionlinxAI_Axis\">
