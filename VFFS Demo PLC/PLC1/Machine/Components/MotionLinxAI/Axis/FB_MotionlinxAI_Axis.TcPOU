    <Method Name="Monitoring" Id="{35f17985-3d10-4a38-b8a2-8d66a31a369c}" FolderPath="I_ComponentBase\">
      <Declaration><![CDATA[METHOD PROTECTED Monitoring
VAR_INPUT
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Busy	 := NOT Stopped;//MotionlinxAI_Motor_Status:=3 OR MotionlinxAI_Motor_Status:=4 ;
_Error	 := eError>0 OR eMotionlinxAIState < MotionlinxAI_States.HOMING;;
_ErrorID := eError;
SUPER^.Monitoring();]]></ST>
      </Implementation>
    </Method>
