    <Method Name="CyclicLogic" Id="{39eda1b4-62f4-459e-961e-ef10a5bb498b}" FolderPath="I_CyclicFB\">
      <Declaration><![CDATA[METHOD CyclicLogic]]></Declaration>
      <Implementation>
        <ST><![CDATA[iCounter	:= iCounter +1;
errorCheck();


Main_Sensor	:= _Controller_Sts.Sensors.4;		//ACTION Need logic to swap sensors dependinf on input group 1 or 2 Main aux
Aux_Sensor	:= _Controller_Sts.Sensors.0;

//
//ACTION Need logic to swap sensors dependinf on input group 1 or 2 Main aux

//////////Set State//////////
//////////Set State//////////
IF _Error THEN
	eMotionlinxAIState := MotionlinxAI_States.ERROR;
ELSIF bSetServo  THEN
	IF bHomed THEN
		IF eMotorStatus > MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_UNBRAKED THEN
			eMotionlinxAIState := MotionlinxAI_States.RUNNING;
		ELSIF eMotorStatus <= MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_UNBRAKED  THEN
			eMotionlinxAIState := MotionlinxAI_States.STOPPED;
		END_IF
	ELSE
		eMotionlinxAIState := MotionlinxAI_States.HOMING;
	END_IF
ELSE
	IF eMotorStatus > MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_UNBRAKED  THEN
		eMotionlinxAIState := MotionlinxAI_States.RUNNING;
	ELSIF eMotorStatus <= MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_UNBRAKED  THEN
		eMotionlinxAIState := MotionlinxAI_States.STOPPED;
	END_IF
END_IF



uMinSpeed := 15+uMaxSpeed/100;


//////////Motor Status//////////
IF iDiagnostics.0 AND iDiagnostics.1 THEN
	eMotorStatus := MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_UNBRAKED;
ELSIF iDiagnostics.0 AND NOT iDiagnostics.1 THEN
	eMotorStatus := MotionlinxAI_Motor_Status.MOTOR_RUNNING_CCW;
ELSIF NOT iDiagnostics.0 AND iDiagnostics.1 THEN
	eMotorStatus := MotionlinxAI_Motor_Status.MOTOR_RUNNING_CW;
ELSIF NOT iDiagnostics.0 AND NOT iDiagnostics.1 THEN
	eMotorStatus := MotionlinxAI_Motor_Status.MOTOR_NOT_RUNNING_BRAKED;
END_IF;

//////////Stop On Disable//////////
IF NOT bEnabled THEN
	oMotorDecel := 500;	
	oMotorControl.0 := FALSE;
//ELSE
//	oMotorDecel := 500;
END_IF;

//////////Set Speeds//////////
oMotorSpeed := LIMIT(UINT_TO_INT(uMinSpeed),UINT_TO_INT(nRequestedSpeed),UINT_TO_INT(uMaxSpeed));

tonAxisStopped(IN:= iPosition=iPreviousPosition, Q => bAxis_Stopped);
iPreviousPosition	:= iPosition;

//One shot the requests
//Extend_RTRIG(CLK := _ExtendRequest);
//Retract_RTRIG(CLK := _RetractRequest);

////Handle Extend
//IF Extend_RTRIG.Q THEN
////	Output			:= TRUE;
//	_Extending		:= TRUE;
//	_Retracting		:= FALSE;
//	_Retracted		:= FALSE;
//	_RetractRequest := FALSE;
//END_IF

////Handle Retract
//IF Retract_RTRIG.Q THEN
////	Output		   := FALSE;
//	_Extending	   := FALSE;
//	_Retracting	   := TRUE;
//	_Extended	   := FALSE;
//	_ExtendRequest := FALSE;
//END_IF

////Handle the time to Extend/Retract
//Extend_TON(IN := _Extending, PT := LREAL_TO_TIME(_ExtendTime));
//Retract_TON(IN := _Retracting, PT := LREAL_TO_TIME(_RetractTime));
//IF Extend_TON.Q THEN
//	_Extended  := TRUE;
//	_Extending := FALSE;
//END_IF

//IF Retract_TON.Q THEN
//	_Retracted	:= TRUE;
//	_Retracting := FALSE;
//END_IF

SUPER^.CyclicLogic();]]></ST>
      </Implementation>
    </Method>
