  <POU Name="FB_MotionlinxAI_Axis" Id="{84bed10e-2014-44a4-86fd-506ddbbef3d2}" SpecialFunc="None">
    <Declaration><![CDATA[(*	
*)
FUNCTION_BLOCK FB_MotionlinxAI_Axis EXTENDS FB_ComponentBase //IMPLEMENTS I_MotionlinxAI_Axis
VAR
	//Controller Status	

	_Controller_Sts	:ST_Controller_Status;
	
	
	
//Inputs
	iServoState	AT%I* : SINT;	
	iPosition 		AT%I* : INT;
	iDiagnostics	AT%I* : INT;
	
	//Speed Limits//
	uMaxSpeed (*AT%I**) : UINT;		//ACTION - IS this from the drive??????
	uMinSpeed : UINT;

//Output
	oMotorControl	AT%Q* : SINT;
	oMotorSpeed		AT%Q* : INT;
	oMotorBrakeMode	AT%Q* : SINT := 2;
	oMotorAccel		AT%Q* : INT;
	oMotorDecel	AT%Q* : INT;
	oServoPos		AT%Q* : INT;
	//Servo Setting//	
	bSetServo : BOOL;
	bHomed : BOOL;
	


	// Internal variables
	//Run Motor//	
	bEnabled : BOOL;
	bRunMotor : BOOL;
	nRequestedSpeed : UINT;


//	iSensors	:INT;
	//Error Resetting//
	//bError : BOOL;
	tpErrorReset : TP;
	//Motor Status//
	eMotorStatus: MotionlinxAI_Motor_Status;
	eErrorRecord : MotionlinxAI_Error_States;
	eMotionlinxAIState : MotionlinxAI_States;
	Main_Sensor	: BOOL;
	Aux_Sensor	: BOOL;
	
	eError : MotionlinxAI_Error_States;
	
	bMotorExpected : BOOL;
	bMotorDisconnected: BOOL;
	
	iPreviousPosition	:int;

	// Timer for Extend/Retract
	tonAxisStopped	:ton:=(PT:=T#0.5S);
	bAxis_Stopped	:BOOL;

	//HMI 
	MotionlinxAI_HMI : ST_MotionlinxAI_Axis_HMI;
	
	iCounter	:int;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
