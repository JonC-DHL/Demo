      <Implementation>
        <ST><![CDATA[


//Set the cylinder to retracted
//oMotorAccel	:= 500;		//From recipe value here
//IF Output THEN
//	_Extended  := TRUE;
//	_Retracted := FALSE;
//ELSE
//	_Extended  := FALSE;
//	_Retracted := TRUE;
//END_IF



//Call base class Initialize
Initialize := SUPER^.Initialize();]]></ST>
      </Implementation>
    </Method>
    <Property Name="IsReady" Id="{b384d1c3-b2d2-456b-9703-0b46c4cb2e78}" FolderPath="I_MotionlinxAI_Axis\">
